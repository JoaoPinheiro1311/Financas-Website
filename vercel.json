{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/auth/(.*)",
      "destination": "/api/identity.py"
    },
    {
      "source": "/api/v1/auth",
      "destination": "/api/identity.py"
    },
    {
      "source": "/api/v1/transactions/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/transactions",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/categories/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/categories",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/summary/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/summary",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/subscriptions/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/subscriptions",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/export/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/chat/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/chat",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/budgets/(.*)",
      "destination": "/api/finance.py"
    },
    {
      "source": "/api/v1/investments/(.*)",
      "destination": "/api/investments.py"
    },
    {
      "source": "/api/v1/investments",
      "destination": "/api/investments.py"
    },
    {
      "source": "/api/v1/goals/(.*)",
      "destination": "/api/goals.py"
    },
    {
      "source": "/api/v1/goals",
      "destination": "/api/goals.py"
    },
    {
      "source": "/api/v1/notifications/(.*)",
      "destination": "/api/notifications.py"
    },
    {
      "source": "/api/v1/notifications",
      "destination": "/api/notifications.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/identity.py"
    },
    {
      "source": "/login/(.*)",
      "destination": "/api/identity.py"
    },
    {
      "source": "/callback/google",
      "destination": "/api/identity.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
